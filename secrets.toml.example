# secrets.toml.example — Plantilla para Streamlit Cloud / .streamlit/secrets.toml
# INSTRUCCIONES:
#   1. Copia este archivo a: .streamlit/secrets.toml
#   2. Rellena tus credenciales reales
#   3. Jamas subas secrets.toml al repositorio (ya esta en .gitignore)

[postgres]
host     = "db.xxxxxxxxxxxx.supabase.co"
port     = "6543"
database = "postgres"
user     = "postgres"
password = "tu_password_supabase"

# Nota: usa el puerto 6543 (PgBouncer Transaction Pooler) para Streamlit Cloud.
# El puerto 5432 (conexion directa) puede agotar el pool con multiples workers.

[app]
QS_ADMIN_USER = "tu_usuario_superadmin"
QS_ADMIN_PASS = "tu_password_muy_segura"
