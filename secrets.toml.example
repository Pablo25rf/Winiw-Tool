# secrets.toml.example — Plantilla para Streamlit Cloud / .streamlit/secrets.toml
# INSTRUCCIONES:
#   1. Copia este archivo a: .streamlit/secrets.toml
#   2. Rellena tus credenciales reales
#   3. Jamas subas secrets.toml al repositorio (ya esta en .gitignore)

[postgres]
host     = "db.xxxxxxxxxxxx.supabase.co"
port     = "5432"
database = "postgres"
user     = "postgres"
password = "tu_password_supabase"

# Usa PgBouncer para mejor rendimiento en produccion:
# port = "6543"

[admin]
WINIW_ADMIN_USER = "tu_usuario_superadmin"
WINIW_ADMIN_PASS = "tu_password_muy_segura"
