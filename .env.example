# ── Credenciales admin (OBLIGATORIAS) ───────────────────────────────────────
# La app no arranca si no estan definidas
WINIW_ADMIN_USER=admin
WINIW_ADMIN_PASS=cambia_esto_por_una_password_segura

# ── PostgreSQL / Supabase (opcional) ─────────────────────────────────────────
# Sin esto la app usa SQLite local automaticamente
# POSTGRES_HOST=db.xxxxxxxxxxxx.supabase.co
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=tu_password_supabase

# ── Alertas por email (opcional) ─────────────────────────────────────────────
